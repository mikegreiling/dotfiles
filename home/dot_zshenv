# Detect LLM agents and ensure GPG pinentry behaves appropriately
if [[ "$CODEX_SHELL" == "1" ]]; then
    export _IS_CODEX=1
fi

if [[ "$CLAUDECODE" == "1" ]]; then
    export _IS_CLAUDE=1
fi

if [[ "$CURSOR_AGENT" == "1" ]]; then
    export _IS_CURSOR=1
fi

if [[ "$_IS_CODEX" == "1" || "$_IS_CLAUDE" == "1" || "$_IS_CURSOR" == "1" ]]; then
    export _IS_LLM_AGENT=1
    export PINENTRY_USER_DATA='no-tty'
else
    export PINENTRY_USER_DATA='tty'
fi

if [[ -x /opt/homebrew/bin/brew ]]; then
    # Homebrew exists at /opt/homebrew for arm64 macOS
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    # or at /usr/local for Intel macOS
    eval "$(/usr/local/bin/brew shellenv)"
elif [[ -x ~/.linuxbrew/bin/brew ]]; then
    eval "$(~/.linuxbrew/bin/brew shellenv)"
elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Prepend asdf shims to PATH (asdf 0.16+ no longer ships asdf.sh —
# we manage PATH ourselves). Must come after `brew shellenv` so the
# shim wins over Homebrew-installed runtimes (e.g. node).
if [[ -d "${ASDF_DATA_DIR:-$HOME/.asdf}/shims" ]]; then
    export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
fi
