#!/bin/bash

# Smart pinentry script for GPG that automatically selects the appropriate
# pinentry interface based on the calling environment:
#
# - PINENTRY_USER_DATA=no-tty: Uses pinentry-mac
# - All other contexts: Uses pinentry-curses
#
# This works by checking the PINENTRY_USER_DATA environment variable, which
# the calling environment can set before invoking GPG. GPG forwards this value
# through to pinentry, allowing us to switch behavior for contexts where a
# terminal UI is undesirable or unsuitable.
#
# Setup:
# 1. The calling environment sets PINENTRY_USER_DATA to "no-tty" when needed
# 2. GPG agent config (~/.gnupg/gpg-agent.conf) contains:
#    pinentry-program /path/to/this/script

# Detect whether the current request should use GUI pinentry.
should_use_gui_pinentry() {
    [[ "$PINENTRY_USER_DATA" == "no-tty" ]]
}

# Select appropriate pinentry program based on environment
if should_use_gui_pinentry; then
    # Non-terminal-friendly environment: use GUI pinentry.
    if command -v pinentry-mac >/dev/null 2>&1; then
        exec pinentry-mac "$@"
    else
        echo "Error: pinentry-mac is not installed. Install it with: brew install pinentry-mac" >&2
        exit 1
    fi
else
    # All other environments: use terminal-based pinentry.
    TERM=xterm-256color exec /opt/homebrew/bin/pinentry-curses "$@"
fi
