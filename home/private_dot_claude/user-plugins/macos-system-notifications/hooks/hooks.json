{
  "description": "Shows sticky macOS notifications for Claude events with auto-dismiss and click-to-activate",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c \"$HOME/.claude/user-plugins/macos-system-notifications/session-start-hook.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c \"$HOME/.claude/user-plugins/macos-system-notifications/dismiss-hook.sh\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c \"$HOME/.claude/user-plugins/macos-system-notifications/notification-hook.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c \"$HOME/.claude/user-plugins/macos-system-notifications/notification-hook.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c \"$HOME/.claude/user-plugins/macos-system-notifications/dismiss-hook.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c \"$HOME/.claude/user-plugins/macos-system-notifications/dismiss-hook.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c \"$HOME/.claude/user-plugins/macos-system-notifications/dismiss-hook.sh\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c \"$HOME/.claude/user-plugins/macos-system-notifications/dismiss-hook.sh\""
          }
        ]
      }
    ]
  }
}
