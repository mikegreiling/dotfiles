{
  "description": "Shows sticky macOS notifications for Claude events with auto-dismiss and click-to-activate (tmux only)",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mike/.claude/user-plugins/tmux-visual-notifications/notification-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/mike/.claude/user-plugins/tmux-visual-notifications/notification-hook.sh"
          }
        ]
      }
    ]
  }
}
