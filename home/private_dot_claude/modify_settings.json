#!/usr/bin/env bash
# chezmoi modify script for ~/.claude/settings.json
#
# Enforces required keys while PRESERVING all other key ordering from the live
# file. jq (without -S) updates existing keys in-place, so Claude Code's key
# order survives round-trips through chezmoi apply — no perpetual sort drift.
#
# To add a new baseline permission: add it to BASELINE_ALLOW below.

set -euo pipefail

BASELINE_ALLOW=$(cat <<'JSON'
[
  "Bash(GITLAB_HOST=gitlab.bstock.io glab:*)",
  "Bash(asdf current:*)",
  "Bash(asdf global:*)",
  "Bash(asdf install:*)",
  "Bash(brew bundle dump:*)",
  "Bash(brew:*)",
  "Bash(chezmoi add:*)",
  "Bash(chezmoi status:*)",
  "Bash(chezmoi target-path:*)",
  "Bash(chmod:*)",
  "Bash(curl:*)",
  "Bash(echo $0)",
  "Bash(echo $SHELL)",
  "Bash(env)",
  "Bash(fi)",
  "Bash(find:*)",
  "Bash(git add:*)",
  "Bash(git branch:*)",
  "Bash(git checkout:*)",
  "Bash(git clone:*)",
  "Bash(git commit:*)",
  "Bash(git diff:*)",
  "Bash(git dt:*)",
  "Bash(git fetch:*)",
  "Bash(git log:*)",
  "Bash(git merge-base:*)",
  "Bash(git pull:*)",
  "Bash(git push:*)",
  "Bash(git rebase:*)",
  "Bash(git restore:*)",
  "Bash(git rev-parse:*)",
  "Bash(git stash:*)",
  "Bash(git status)",
  "Bash(git worktree:*)",
  "Bash(glab:*)",
  "Bash(grep:*)",
  "Bash(ls:*)",
  "Bash(mkdir:*)",
  "Bash(node:*)",
  "Bash(npm ci)",
  "Bash(npm info:*)",
  "Bash(npm install:*)",
  "Bash(npm run dev:*)",
  "Bash(npm run eslint:*)",
  "Bash(npm run lint:*)",
  "Bash(npm run prettier:*)",
  "Bash(npm run prettier:fix:*)",
  "Bash(npm run test:*)",
  "Bash(npm run type-check:*)",
  "Bash(npm test:*)",
  "Bash(npm update:*)",
  "Bash(npx eslint:*)",
  "Bash(npx prettier:*)",
  "Bash(npx tsc:*)",
  "Bash(npx vitest run:*)",
  "Bash(open:*)",
  "Bash(ps:*)",
  "Bash(sed:*)",
  "Edit(~/.claude/caches/*.md)",
  "Read(~/.claude/**)",
  "Read(~/.claude/caches/*.md)",
  "Read(~/.local/share/chezmoi/**)",
  "Read(~/.local/share/chezmoi/CLAUDE.md)",
  "Read(~/Projects/bstock-projects/**/.mcp.json)",
  "Read(~/Projects/bstock-projects/**/CLAUDE.md)",
  "Read(~/Projects/bstock-projects/**/package.json)",
  "WebFetch(domain:developers.google.com)",
  "WebFetch(domain:docs.anthropic.com)",
  "WebFetch(domain:docs.gitlab.com)",
  "WebFetch(domain:github.com)",
  "WebFetch(domain:gitlab.bstock.io)",
  "WebFetch(domain:raw.githubusercontent.com)",
  "WebSearch",
  "mcp__atlassian__addCommentToJiraIssue",
  "mcp__atlassian__atlassianUserInfo",
  "mcp__atlassian__createJiraIssue",
  "mcp__atlassian__editJiraIssue",
  "mcp__atlassian__getAccessibleAtlassianResources",
  "mcp__atlassian__getConfluencePage",
  "mcp__atlassian__getConfluencePageAncestors",
  "mcp__atlassian__getConfluencePageDescendants",
  "mcp__atlassian__getConfluencePageFooterComments",
  "mcp__atlassian__getConfluencePageInlineComments",
  "mcp__atlassian__getConfluenceSpaces",
  "mcp__atlassian__getJiraIssue",
  "mcp__atlassian__getJiraIssueRemoteIssueLinks",
  "mcp__atlassian__getJiraProjectIssueTypesMetadata",
  "mcp__atlassian__getPagesInConfluenceSpace",
  "mcp__atlassian__getTransitionsForJiraIssue",
  "mcp__atlassian__getVisibleJiraProjects",
  "mcp__atlassian__lookupJiraAccountId",
  "mcp__atlassian__searchConfluenceUsingCql",
  "mcp__atlassian__searchJiraIssuesUsingJql",
  "mcp__atlassian__transitionJiraIssue",
  "mcp__context7__get-library-docs",
  "mcp__context7__resolve-library-id",
  "mcp__ide__getDiagnostics"
]
JSON
)

input=$(cat)
[[ -z "$input" ]] && input='{}'

printf '%s' "$input" | jq --argjson baseline "$BASELINE_ALLOW" '
  # Enforced static keys — chezmoi owns these; Claude Code must not override them
  .env.HUSKY = "0" |
  .statusLine = {"type":"command","command":"npx -y ccstatusline@latest","padding":0} |
  .permissions.defaultMode = "auto" |
  .permissions.deny = ["Bash(chezmoi cd:*)"] |
  .permissions.ask = ["Bash(chezmoi apply:*)"] |
  .skipDangerousModePermissionPrompt = true |
  .skipAutoPermissionPrompt = true |

  # Additive allow list: union baseline with whatever is currently on disk,
  # deduped and sorted. Claude Code appends to this list on "always allow";
  # the union ensures chezmoi can push new defaults without clobbering local grants.
  .permissions.allow = (($baseline + (.permissions.allow // [])) | unique)
'
