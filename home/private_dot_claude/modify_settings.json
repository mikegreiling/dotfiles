-}}
{{- $liveAllow := list -}}
{{- if hasKey $cfg "permissions" -}}
  {{- $perms := index $cfg "permissions" -}}
  {{- if hasKey $perms "allow" -}}
    {{- $liveAllow = index $perms "allow" -}}
  {{- end -}}
{{- end -}}
{{- $cfg = setValueAtPath "permissions.allow" (concat $baselineAllow $liveAllow | uniq | sortAlpha) $cfg -}}

{{ $cfg | toPrettyJson -}}
