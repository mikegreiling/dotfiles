{{- /* chezmoi:modify-template */ -}}
{{- $cfg := dict -}}
{{- if .chezmoi.stdin -}}
  {{- $cfg = fromJson .chezmoi.stdin -}}
{{- end -}}

{{- /* Enforced static keys — chezmoi owns these */ -}}
{{- $cfg = setValueAtPath "env" (dict "HUSKY" "0") $cfg -}}
{{- $cfg = setValueAtPath "statusLine" (dict "type" "command" "command" "npx -y ccstatusline@latest" "padding" 0) $cfg -}}
{{- $cfg = setValueAtPath "permissions.defaultMode" "auto" $cfg -}}
{{- $cfg = setValueAtPath "permissions.deny" (list "Bash(chezmoi cd:*)") $cfg -}}
{{- $cfg = setValueAtPath "permissions.ask" (list "Bash(chezmoi apply:*)" "Bash(rm:*)") $cfg -}}
{{- $cfg = setValueAtPath "skipDangerousModePermissionPrompt" true $cfg -}}
{{- $cfg = setValueAtPath "skipAutoPermissionPrompt" true $cfg -}}

{{- /*
  Additive baseline for permissions.allow.
  Claude Code appends to this list when the user clicks "always allow",
  so we union the chezmoi baseline with whatever's currently on disk
  rather than overwriting. Result: chezmoi can push new defaults to
  fresh machines without clobbering local grants.
*/ -}}
