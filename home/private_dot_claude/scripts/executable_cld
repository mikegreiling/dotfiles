#!/opt/homebrew/bin/bash

# cld - Claude CLI convenience wrapper
# Provides session ID expansion, tmux integration, and spatial forking
# See CLD_API_SPEC.md for full documentation
#
# Flag Handling:
# - cld-specific flags (-y/--yes, -n/--no) are parsed and stripped before passing to claude
# - All other flags/options are passed through to the claude command unchanged
# - --resume is REJECTED when used with 'cld resume' or 'cld fork' (generates error)
#   since these subcommands already handle session resumption
# - Examples:
#   cld resume -y abc123 --model sonnet   → strips -y, passes --model sonnet to claude
#   cld -n --output-format json           → strips -n, passes --output-format json to claude
#   cld resume abc123 --resume            → ERROR: Cannot use --resume with 'resume' subcommand

set -euo pipefail

# Detect Claude binary location (prefer PATH, fallback to hardcoded location)
if command -v claude &>/dev/null; then
  readonly CLAUDE_BIN="claude"
else
  readonly CLAUDE_BIN="${HOME}/.claude/local/claude"
fi

# Exit codes
readonly EXIT_SUCCESS=0
readonly EXIT_INVALID_INPUT=1
readonly EXIT_NO_MATCHES=2
readonly EXIT_AMBIGUOUS=3
readonly EXIT_NOT_IN_TMUX=4
readonly EXIT_NO_METADATA=5
readonly EXIT_ELSEWHERE_FAILED=6
readonly EXIT_NESTED_CLAUDE=7

# Valid location options for elsewhere
readonly VALID_LOCATIONS=("up" "down" "left" "right" "pane" "tab" "window")

# ============================================================================
# Utility Functions
# ============================================================================

error() {
  echo "Error: $*" >&2
}

info() {
  echo "$*"
}

# Check if we're running inside Claude Code
is_inside_claude_code() {
  [[ -n "${CLAUDECODE:-}" ]]
}

# Check if we're running in tmux
is_in_tmux() {
  [[ -n "${TMUX:-}" ]]
}

# Read session ID from tmux metadata
read_tmux_session_id() {
  if ! is_in_tmux; then
    error "Not running in a tmux session."
    error "This command requires tmux. Start tmux first or provide an explicit session ID."
    exit "$EXIT_NOT_IN_TMUX"
  fi

  local session_id
  # Prefer new @meta.claude.session_id, fall back to legacy @claude_session
  session_id=$(tmux show-options -pv @meta.claude.session_id 2>/dev/null || true)
  if [[ -z "$session_id" ]]; then
    session_id=$(tmux show-options -pv @claude_session 2>/dev/null || true)
  fi

  if [[ -z "$session_id" ]]; then
    error "No Claude session found in current tmux pane."
    error "Run 'cld resume <session-id>' with an explicit session ID instead."
    exit "$EXIT_NO_METADATA"
  fi

  echo "$session_id"
}

# Validate that a string is a valid partial or full session ID
validate_partial_session_id() {
  local partial_id="$1"

  # Accept any prefix of a UUID (at least 6 chars, only hex and dashes)
  # Examples: 23e30f, 23e30f82, 23e30f82-be, 23e30f82-bee0-4861-8bd3-869ca8a5c8a3
  if [[ ! "$partial_id" =~ ^[0-9a-f-]{6,}$ ]]; then
    error "Invalid session ID format."
    error "Must be at least 6 characters and contain only lowercase hex digits and dashes."
    error "Examples: 23e30f, 23e30f82-be, 23e30f82-bee0-4861-8bd3-869ca8a5c8a3"
    exit "$EXIT_INVALID_INPUT"
  fi

  # Remove dashes for length check
  local hex_only="${partial_id//-/}"
  if [[ ${#hex_only} -lt 6 ]]; then
    error "Session ID must contain at least 6 hexadecimal characters (excluding dashes)."
    error "Example: 23e30f"
    exit "$EXIT_INVALID_INPUT"
  fi
}

# Validate that a string is a usable directory path
# Returns 0 if valid, 1 if invalid
is_valid_directory_path() {
  local path="$1"

  # Empty path is invalid
  [[ -z "$path" ]] && return 1

  # Must be an absolute path (starts with /)
  [[ "$path" != /* ]] && return 1

  # Reject paths containing quote characters (indicates malformed metadata)
  [[ "$path" == *\"* || "$path" == *\'* ]] && return 1

  # Directory must exist
  [[ ! -d "$path" ]] && return 1

  return 0
}

# Format a Unix timestamp into human-readable string with timezone
# Output example: "Mon Feb  9 14:23:45 2026 (CST)"
format_timestamp() {
  local timestamp="$1"
  local formatted

  # macOS uses -r, Linux uses -d @
  # %Z gives timezone abbreviation (CST, EST, UTC, etc.)
  formatted=$(date -r "$timestamp" "+%a %b %e %H:%M:%S %Y (%Z)" 2>/dev/null) || \
    formatted=$(date -d "@$timestamp" "+%a %b %e %H:%M:%S %Y (%Z)" 2>/dev/null) || \
    formatted="unknown"

  echo "$formatted"
}

# Sessions older than this may have been purged (3 weeks in seconds)
readonly SESSION_AGE_WARNING_SECONDS=$((21 * 24 * 60 * 60))

# Find session transcript file and return its path
find_session_transcript() {
  local session_id="$1"
  find ~/.claude/projects -name "${session_id}.jsonl" -print -quit 2>/dev/null
}

# Get modification time of a session transcript file
# Returns empty string if file doesn't exist or stat fails
get_session_mtime() {
  local session_file="$1"
  [[ -z "$session_file" ]] && return

  # macOS stat uses -f %m, Linux uses -c %Y
  stat -f %m "$session_file" 2>/dev/null || stat -c %Y "$session_file" 2>/dev/null || true
}

# Get the last hook timestamp from tmux metadata
# Returns empty string if not in tmux or no metadata available
get_tmux_hook_timestamp() {
  if is_in_tmux; then
    tmux show-options -pv @meta.claude.latest_hook_time 2>/dev/null || true
  fi
}

# Display session information preamble before resume
# Parameters:
#   $1 - session_id
#   $2 - session_file (empty if not found)
#   $3 - session_mtime (empty if not available)
#   $4 - use_tmux_metadata ("true" or "false") - only valid for current pane's session
show_session_preamble() {
  local session_id="$1"
  local session_file="$2"
  local session_mtime="$3"
  local use_tmux_metadata="${4:-false}"

  if [[ -n "$session_file" ]]; then
    # Session transcript found
    info "Session found: $session_id"
    if [[ -n "$session_mtime" ]]; then
      local formatted_time
      formatted_time=$(format_timestamp "$session_mtime")
      info "Last activity: $formatted_time"
    fi
  else
    # Session transcript NOT found - warn user
    info "Session: $session_id"

    # Only try tmux metadata if this is the current pane's session
    if [[ "$use_tmux_metadata" == "true" ]]; then
      local hook_time
      hook_time=$(get_tmux_hook_timestamp)

      if [[ -n "$hook_time" ]]; then
        local formatted_time
        formatted_time=$(format_timestamp "$hook_time")
        local current_time
        current_time=$(date +%s)
        local age=$((current_time - hook_time))

        if [[ $age -gt $SESSION_AGE_WARNING_SECONDS ]]; then
          echo "⚠ Warning: No transcript found. Last activity was $formatted_time." >&2
          echo "  Session likely expired. claude --resume is likely to fail." >&2
        else
          echo "⚠ Warning: No transcript found. Last activity was $formatted_time." >&2
          echo "  claude --resume is likely to fail." >&2
        fi
      else
        echo "⚠ Warning: No transcript found. The session may no longer be available." >&2
        echo "  claude --resume is likely to fail." >&2
      fi
    else
      # Explicit session ID - don't use tmux metadata
      echo "⚠ Warning: No transcript found. The session may no longer be available." >&2
      echo "  claude --resume is likely to fail." >&2
    fi
  fi

  echo "" # Blank line before directory prompt or launch message
}

# Extract session ID from filename
extract_session_id() {
  local filename="$1"
  if [[ "$filename" =~ ([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}) ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

# Expand partial session ID to full UUID
expand_session_id() {
  local partial_id="$1"

  validate_partial_session_id "$partial_id"

  # If it's already a full UUID, just return it
  if [[ "$partial_id" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
    echo "$partial_id"
    return
  fi

  # Strip dashes from the partial ID for comparison
  local search_string="${partial_id//-/}"

  # Initialize associative array for unique sessions
  declare -A unique_sessions

  # Helper function to check if a filename matches our search string
  # Compares dashless versions to handle any dash placement
  matches_search() {
    local filename="$1"
    local filename_nodashes="${filename//-/}"
    [[ "$filename_nodashes" == "${search_string}"* ]]
  }

  # Step 1: Search project transcript files first (authoritative source)
  # Note: We use mapfile to avoid subshell issues with process substitution
  local -a project_files
  mapfile -t -d '' project_files < <(find ~/.claude/projects -type f -name "*.jsonl" -print0 2>/dev/null)

  for file in "${project_files[@]}"; do
    [[ -z "$file" ]] && continue
    local filename
    filename=$(basename "$file")
    if matches_search "$filename"; then
      local session_id
      session_id=$(extract_session_id "$filename")
      if [[ -n "$session_id" ]] && [[ ! "$session_id" =~ -agent- ]]; then
        unique_sessions["$session_id"]=1
      fi
    fi
  done

  # Step 2: If no matches in projects, try todo files for newly-started sessions
  local array_size=0
  # Safely get array size even if array is empty or unset
  set +u  # Temporarily disable unbound variable check
  array_size=${#unique_sessions[@]}
  set -u  # Re-enable unbound variable check
  if [[ "$array_size" -eq 0 ]]; then
    local -a todo_files
    mapfile -t -d '' todo_files < <(find ~/.claude/todos -type f -name "*.json" -print0 2>/dev/null)

    for file in "${todo_files[@]}"; do
      [[ -z "$file" ]] && continue
      local filename
      filename=$(basename "$file")
      if matches_search "$filename"; then
        local session_id
        session_id=$(extract_session_id "$filename")
        if [[ -n "$session_id" ]] && [[ ! "$session_id" =~ -agent- ]]; then
          unique_sessions["$session_id"]=1
        fi
      fi
    done
  fi

  # Check how many unique sessions we found
  local session_count=0
  # Safely get array size even if array is empty or unset
  set +u  # Temporarily disable unbound variable check
  session_count=${#unique_sessions[@]}
  set -u  # Re-enable unbound variable check

  if [[ $session_count -eq 0 ]]; then
    error "No sessions found matching '$partial_id'."
    error "Run 'claude --resume' to see available sessions in interactive picker."
    exit "$EXIT_NO_MATCHES"
  elif [[ $session_count -gt 1 ]]; then
    error "Multiple sessions found matching '$partial_id':"
    for session in "${!unique_sessions[@]}"; do
      echo "  - $session" >&2
    done
    echo "" >&2
    error "Please provide more characters to uniquely identify the session."
    exit "$EXIT_AMBIGUOUS"
  fi

  # Return the single session ID
  for session_id in "${!unique_sessions[@]}"; do
    echo "$session_id"
    return
  done
}

# Encode current directory to lossy format for comparison
encode_current_directory() {
  local dir="$PWD"
  dir="${dir#/}"
  # Replace all non-alphanumeric with dash
  dir=$(echo "$dir" | sed 's/[^a-zA-Z0-9]/-/g')
  echo "-$dir"
}

# Match encoded prefix against directory name
# Returns number of encoded characters matched via echo, or exits with code 1 if no match
match_prefix() {
  local encoded="$1"
  local dirname="$2"

  local enc_idx=0
  local dir_idx=0
  local enc_len=${#encoded}
  local dir_len=${#dirname}
  local last_dash_idx=-1

  while [[ $enc_idx -lt $enc_len && $dir_idx -lt $dir_len ]]; do
    local enc_char="${encoded:$enc_idx:1}"
    local dir_char="${dirname:$dir_idx:1}"

    if [[ "$enc_char" =~ [a-zA-Z0-9] ]]; then
      # Alphanumeric must match exactly
      if [[ "$enc_char" == "$dir_char" ]]; then
        enc_idx=$((enc_idx + 1))
        dir_idx=$((dir_idx + 1))
      else
        # Mismatch
        return 1
      fi
    elif [[ "$enc_char" == "-" ]]; then
      # Remember this dash position
      last_dash_idx=$enc_idx

      # Dash can match any non-alphanumeric
      if [[ ! "$dir_char" =~ [a-zA-Z0-9] ]]; then
        # Consume non-alphanumeric from dirname
        dir_idx=$((dir_idx + 1))
        # Don't advance enc_idx yet - this dash might match multiple chars
      else
        # We've hit alphanumeric in dirname, this dash group is done
        enc_idx=$((enc_idx + 1))
      fi
    fi
  done

  # Return how many encoded chars we consumed
  echo "$enc_idx"
  return 0
}

# Greedy pattern-matching decoder
decode_and_validate_path() {
  local encoded="$1"

  # Quick check: Does current directory match?
  local current_encoded
  current_encoded=$(encode_current_directory)
  if [[ "$encoded" == "$current_encoded" ]]; then
    echo "$PWD"
    return 0
  fi

  # Remove leading dash
  encoded="${encoded#-}"

  local current_path=""
  local remaining="$encoded"

  while [[ -n "$remaining" ]]; do
    # Get next directory component
    local best_match=""
    local best_match_len=0

    # List subdirectories (including hidden)
    local search_path="${current_path:-/}"
    while IFS= read -r -d '' subdir; do
      local dirname
      dirname=$(basename "$subdir")

      # Try to match prefix (capture output and ignore exit code)
      local matched_len
      matched_len=$(match_prefix "$remaining" "$dirname" 2>/dev/null || true)
      if [[ -n "$matched_len" && $matched_len -gt $best_match_len ]]; then
        best_match="$dirname"
        best_match_len=$matched_len
      fi
    done < <(find "$search_path" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)

    if [[ -z "$best_match" ]]; then
      # No match found
      return 1
    fi

    # Update path and remaining
    if [[ -z "$current_path" ]]; then
      current_path="/$best_match"
    else
      current_path="$current_path/$best_match"
    fi

    remaining="${remaining:$best_match_len}"

    # Skip exactly ONE leading dash if present (represents /)
    # Multiple consecutive dashes represent encoded special characters, so don't strip them all
    if [[ "${remaining:0:1}" == "-" ]]; then
      remaining="${remaining:1}"
    fi
  done

  echo "$current_path"
  return 0
}

# Get session directory from metadata or decode from transcript path
get_session_directory() {
  local session_id="$1"

  # Try tmux metadata first (with validation)
  local metadata_dir=""
  if is_in_tmux; then
    local raw_metadata
    raw_metadata=$(tmux show-options -pv @meta.claude.session_dir 2>/dev/null || true)
    # Only use metadata if it's a valid directory path
    # This ensures transcript decoding is used when metadata is corrupted
    if is_valid_directory_path "$raw_metadata"; then
      metadata_dir="$raw_metadata"
    fi
  fi

  # Find transcript file
  local session_file
  session_file=$(find ~/.claude/projects -name "${session_id}.jsonl" -print -quit 2>/dev/null)

  if [[ -z "$session_file" ]]; then
    # No transcript found, use metadata if available
    if [[ -n "$metadata_dir" ]]; then
      echo "$metadata_dir"
    fi
    return
  fi

  # Extract encoded directory name
  local encoded_dir
  encoded_dir=$(basename "$(dirname "$session_file")")

  # Decode and validate the path
  local decoded_dir
  if ! decoded_dir=$(decode_and_validate_path "$encoded_dir" 2>/dev/null); then
    # Decoding failed, fall back to metadata
    if [[ -n "$metadata_dir" ]]; then
      echo "$metadata_dir"
    fi
    return
  fi

  # Validate metadata against decoded path (if both exist)
  if [[ -n "$metadata_dir" && "$metadata_dir" != "$decoded_dir" ]]; then
    # Mismatch detected
    error "Warning: Metadata path differs from transcript location"
    error "  Metadata: $metadata_dir"
    error "  Transcript: $decoded_dir"
    echo -n "Resume anyway using transcript path? [Yn] " >&2

    local reply
    read -r -n 1 reply
    echo "" >&2

    if [[ -z "$reply" || "$reply" =~ ^[Yy]$ ]]; then
      echo "$decoded_dir"
    else
      exit "$EXIT_INVALID_INPUT"
    fi
  else
    # No conflict, use decoded path (or metadata if decode failed)
    echo "${decoded_dir:-$metadata_dir}"
  fi
}

# Check if directory matches
check_directory_match() {
  local session_dir="$1"
  [[ -n "$session_dir" && "$PWD" == "$session_dir" ]]
}

# Check if a location is valid
is_valid_location() {
  local location="$1"
  for valid in "${VALID_LOCATIONS[@]}"; do
    if [[ "$location" == "$valid" ]]; then
      return 0
    fi
  done
  return 1
}

# Check if options array contains conflicting resume/continue flags
validate_options_for_subcommand() {
  local subcommand="$1"
  shift
  local options=("$@")

  for opt in "${options[@]}"; do
    if [[ "$opt" == "--resume" ]]; then
      if [[ "$subcommand" == "resume" || "$subcommand" == "fork" ]]; then
        error "Cannot use --resume with '$subcommand' subcommand."
        error "The subcommand already handles session resumption."
        exit "$EXIT_INVALID_INPUT"
      fi
    elif [[ "$opt" == "--continue" ]]; then
      if [[ "$subcommand" == "fork" ]]; then
        error "Cannot use --continue with 'fork' subcommand."
        error "Use 'cld' or 'cld resume' with --continue instead."
        exit "$EXIT_INVALID_INPUT"
      fi
    fi
  done
}

# Interactive prompt to resume previous session
# Returns 0 if user wants to resume, 1 if not
prompt_resume() {
  local session_id="$1"

  echo "Previous session found: ${session_id:0:40}..." >&2
  echo -n "Would you like to resume? [Yn] " >&2

  local reply
  read -r -n 1 reply
  echo "" >&2  # New line after single char input

  # Default to yes if empty (just pressed enter)
  if [[ -z "$reply" || "$reply" =~ ^[Yy]$ ]]; then
    return 0
  else
    return 1
  fi
}

# ============================================================================
# Command Implementations
# ============================================================================

# Resume a Claude session
cmd_resume() {
  local session_id="$1"
  shift

  # Parse flags
  local auto_yes=false
  local auto_no=false
  local dry_run=false
  local clean_options=()

  for opt in "$@"; do
    case "$opt" in
      -y|--yes)
        auto_yes=true
        ;;
      -n|--no)
        auto_no=true
        ;;
      --dry-run)
        dry_run=true
        ;;
      *)
        clean_options+=("$opt")
        ;;
    esac
  done

  # Check if running inside Claude Code (not allowed without elsewhere or dry-run)
  if is_inside_claude_code && [[ "$dry_run" != "true" ]]; then
    error "Cannot run claude inside a Claude Code session."
    error "Use 'cld fork <location>' to run in a new pane/window/tab."
    error "Examples:"
    error "  cld fork pane    # Fork to new pane"
    error "  cld fork tab     # Fork to new window/tab"
    error "  cld fork right   # Fork to pane on the right"
    exit "$EXIT_NESTED_CLAUDE"
  fi

  # Get or expand session ID
  local explicit_session_id="$session_id"  # Track if explicit ID was provided
  if [[ -z "$session_id" ]]; then
    session_id=$(read_tmux_session_id)
  else
    session_id=$(expand_session_id "$session_id")
  fi

  # Find session transcript and get metadata
  local session_file
  session_file=$(find_session_transcript "$session_id")
  local session_mtime
  session_mtime=$(get_session_mtime "$session_file")

  # Use tmux metadata only if no explicit session ID was provided
  local use_tmux_metadata="false"
  [[ -z "$explicit_session_id" ]] && use_tmux_metadata="true"

  # Show session preamble
  show_session_preamble "$session_id" "$session_file" "$session_mtime" "$use_tmux_metadata"

  # Get session directory with validation
  local session_dir
  session_dir=$(get_session_directory "$session_id")

  # Final safety check - if session_dir somehow contains invalid data, clear it
  if [[ -n "$session_dir" ]] && ! is_valid_directory_path "$session_dir"; then
    session_dir=""
  fi

  # Handle directory switching
  if [[ -n "$session_dir" ]] && ! check_directory_match "$session_dir"; then
    if [[ "$auto_no" == true ]]; then
      info "Session resume cancelled (--no flag)"
      exit "$EXIT_SUCCESS"
    elif [[ "$auto_yes" == true ]]; then
      info "Changing to: $session_dir"
      cd "$session_dir" || {
        error "Failed to change to directory: $session_dir"
        exit "$EXIT_INVALID_INPUT"
      }
    else
      # Interactive prompt
      info "Session started in: $session_dir"
      info "Currently in: $PWD"
      echo -n "Change directory and resume? [Yn] " >&2

      local reply
      read -r -n 1 reply
      echo "" >&2

      if [[ "$reply" == $'\e' ]]; then
        info "Session resume cancelled"
        exit "$EXIT_SUCCESS"
      elif [[ -z "$reply" || "$reply" =~ ^[Yy]$ ]]; then
        cd "$session_dir" || {
          error "Failed to change to directory: $session_dir"
          exit "$EXIT_INVALID_INPUT"
        }
      else
        info "Session resume cancelled"
        exit "$EXIT_SUCCESS"
      fi
    fi
  fi

  # Exit early if dry-run mode
  if [[ "$dry_run" == "true" ]]; then
    echo "" # Blank line
    info "DRY RUN: Would launch: $CLAUDE_BIN --resume $session_id"
    if [[ ${#clean_options[@]} -gt 0 ]]; then
      info "DRY RUN: Additional options: ${clean_options[*]}"
    fi
    exit "$EXIT_SUCCESS"
  fi

  echo "" # Blank line
  info "Launching: $CLAUDE_BIN --resume $session_id"

  # Handle empty clean_options array properly
  if [[ ${#clean_options[@]} -eq 0 ]]; then
    exec "$CLAUDE_BIN" --resume "$session_id"
  else
    exec "$CLAUDE_BIN" --resume "$session_id" "${clean_options[@]}"
  fi
}

# Fork a Claude session
cmd_fork() {
  local session_id="${1:-}"
  shift
  local options=("$@")

  # Check if running inside Claude Code without a location
  if is_inside_claude_code; then
    # Default to 'pane' location when inside Claude Code
    cmd_fork_elsewhere "pane" "$session_id" "${options[@]}"
    return
  fi

  # Not inside Claude Code, proceed with regular fork
  local explicit_session_id="$session_id"
  if [[ -z "$session_id" ]]; then
    # No session ID provided, read from tmux metadata
    session_id=$(read_tmux_session_id)
  else
    # Expand partial session ID to full UUID
    session_id=$(expand_session_id "$session_id")
  fi

  # Find session transcript and get metadata
  local session_file
  session_file=$(find_session_transcript "$session_id")
  local session_mtime
  session_mtime=$(get_session_mtime "$session_file")

  # Use tmux metadata only if no explicit session ID was provided
  local use_tmux_metadata="false"
  [[ -z "$explicit_session_id" ]] && use_tmux_metadata="true"

  # Show session preamble
  show_session_preamble "$session_id" "$session_file" "$session_mtime" "$use_tmux_metadata"

  info "Launching: $CLAUDE_BIN --resume $session_id --fork-session"
  exec "$CLAUDE_BIN" --resume "$session_id" --fork-session "${options[@]}"
}

# Fork a Claude session to a new location using run-elsewhere
cmd_fork_elsewhere() {
  local location="$1"
  local session_id="${2:-}"
  shift 2
  local options=("$@")

  # Validate location
  if ! is_valid_location "$location"; then
    error "Invalid location '$location'."
    error "Valid locations: ${VALID_LOCATIONS[*]}"
    exit "$EXIT_INVALID_INPUT"
  fi

  # Check if in tmux (required for elsewhere)
  if ! is_in_tmux; then
    error "Not running in a tmux session."
    error "Spatial forking requires tmux. Start tmux first."
    exit "$EXIT_NOT_IN_TMUX"
  fi

  # Determine session ID
  local explicit_session_id="$session_id"
  if [[ -z "$session_id" ]]; then
    # No session ID provided, read from tmux metadata
    session_id=$(read_tmux_session_id)
  else
    # Expand partial session ID to full UUID
    session_id=$(expand_session_id "$session_id")
  fi

  # Find session transcript and get metadata
  local session_file
  session_file=$(find_session_transcript "$session_id")
  local session_mtime
  session_mtime=$(get_session_mtime "$session_file")

  # Use tmux metadata only if no explicit session ID was provided
  local use_tmux_metadata="false"
  [[ -z "$explicit_session_id" ]] && use_tmux_metadata="true"

  # Show session preamble (in current pane, before spawning elsewhere)
  show_session_preamble "$session_id" "$session_file" "$session_mtime" "$use_tmux_metadata"

  # Get session's project directory (not current working directory)
  local session_dir
  session_dir=$(get_session_directory "$session_id")

  # Fallback to current directory if we can't determine session directory
  local cwd="${session_dir:-$PWD}"

  # Construct the command string (with proper escaping)
  local cmd_string="cd '$cwd' && $CLAUDE_BIN --resume $session_id --fork-session"
  # Append options if any
  if [[ ${#options[@]} -gt 0 ]]; then
    cmd_string="$cmd_string ${options[*]}"
  fi

  # Build the elsewhere command as an array
  local elsewhere_cmd=(npx -y run-elsewhere --no-tty --"$location" -c "$cmd_string")

  info "Forking session $session_id to $location..."
  info "Command: ${elsewhere_cmd[*]}"

  # Execute via run-elsewhere
  if ! "${elsewhere_cmd[@]}"; then
    error "Failed to execute run-elsewhere."
    error "Make sure the package is available: npx -y run-elsewhere --version"
    exit "$EXIT_ELSEWHERE_FAILED"
  fi
}

# ============================================================================
# Main Command Router
# ============================================================================

main() {
  # Parse arguments: determine what kind of invocation this is
  local first_arg="${1:-}"

  # Case 1: Explicit subcommands (cld resume, cld fork)
  # Check this FIRST before flag detection to avoid confusion
  if [[ "$first_arg" == "resume" || "$first_arg" == "fork" ]]; then
    # Jump directly to subcommand handler (implemented below)
    :  # noop, will fall through to subcommand handler
  # Case 2: No arguments or flags with implicit resume (cld, cld -y, cld --model)
  elif [[ $# -eq 0 || "$first_arg" =~ ^- ]]; then
    # Check for cld-specific flags
    local has_yes_flag=false
    local has_no_flag=false

    for arg in "$@"; do
      [[ "$arg" == "-y" || "$arg" == "--yes" ]] && has_yes_flag=true
      [[ "$arg" == "-n" || "$arg" == "--no" ]] && has_no_flag=true
    done

    # If we have cld-specific flags or no args, try implicit resume
    if [[ $# -eq 0 || "$has_yes_flag" == true || "$has_no_flag" == true ]]; then
      if is_in_tmux; then
        local session_id
        session_id=$(tmux show-options -pv @meta.claude.session_id 2>/dev/null || true)
        if [[ -z "$session_id" ]]; then
          session_id=$(tmux show-options -pv @claude_session 2>/dev/null || true)
        fi

        if [[ -n "$session_id" ]]; then
          local session_dir
          session_dir=$(get_session_directory "$session_id")

          # Validate session_dir is usable
          if [[ -n "$session_dir" ]] && ! is_valid_directory_path "$session_dir"; then
            session_dir=""
          fi

          local needs_cd=false
          [[ -n "$session_dir" ]] && ! check_directory_match "$session_dir" && needs_cd=true

          if [[ "$has_no_flag" == true ]]; then
            # Auto-deny: start new session
            exec "$CLAUDE_BIN" "${@}"
          elif [[ "$has_yes_flag" == true ]]; then
            # Auto-accept: cd if needed and resume
            if [[ "$needs_cd" == true ]]; then
              cd "$session_dir" || {
                error "Failed to change to directory: $session_dir"
                exit "$EXIT_INVALID_INPUT"
              }
            fi
            cmd_resume "$session_id" "${@}"
          else
            # Interactive combined prompt
            if [[ "$needs_cd" == true ]]; then
              echo "Resume session ${session_id:0:8} from $session_dir? [Yn] " >&2
            else
              echo "Resume session ${session_id:0:8}? [Yn] " >&2
            fi

            local reply
            read -r -n 1 reply
            echo "" >&2

            # Check for ESC key (ASCII 27)
            if [[ "$reply" == $'\e' ]]; then
              exec "$CLAUDE_BIN"
            elif [[ -z "$reply" || "$reply" =~ ^[Yy]$ ]]; then
              if [[ "$needs_cd" == true ]]; then
                cd "$session_dir" || {
                  error "Failed to change to directory: $session_dir"
                  exit "$EXIT_INVALID_INPUT"
                }
              fi
              cmd_resume "$session_id"
            else
              exec "$CLAUDE_BIN"
            fi
          fi
        else
          # No previous session
          exec "$CLAUDE_BIN" "$@"
        fi
      else
        # Not in tmux
        exec "$CLAUDE_BIN" "$@"
      fi
      return
    else
      # Has flags but not our flags, pass through to claude
      exec "$CLAUDE_BIN" "$@"
      return
    fi
  # Case 3: Unknown command, pass through
  else
    exec "$CLAUDE_BIN" "$@"
    return
  fi

  # If we reached here, first_arg is a known subcommand (resume or fork)
  # Continue with subcommand processing

  # Check if first arg is a known subcommand
  if [[ "$first_arg" == "resume" || "$first_arg" == "fork" ]]; then
    local subcommand="$first_arg"
    shift

    # Collect remaining args (will parse into session-id/location and options)
    local remaining_args=("$@")
    local options=()
    local non_option_args=()

    # Separate options from non-option arguments
    for arg in "${remaining_args[@]}"; do
      if [[ "$arg" =~ ^- ]]; then
        options+=("$arg")
      else
        non_option_args+=("$arg")
      fi
    done

    # Validate options for this subcommand
    validate_options_for_subcommand "$subcommand" "${options[@]}"

    # Route to appropriate command
    case "$subcommand" in
      resume)
        # cld resume [session-id] [options...]
        local session_id="${non_option_args[0]:-}"
        cmd_resume "$session_id" "${options[@]}"
        ;;

      fork)
        # cld fork [location] [session-id] [options...]
        # Need to determine if first arg is a location or session ID

        if [[ ${#non_option_args[@]} -eq 0 ]]; then
          # cld fork (no args, just options)
          cmd_fork "" "${options[@]}"
        elif [[ ${#non_option_args[@]} -eq 1 ]]; then
          # cld fork <arg> [options...]
          # Could be either location or session-id
          local arg="${non_option_args[0]}"

          if is_valid_location "$arg"; then
            # It's a location: cld fork <location> [options...]
            cmd_fork_elsewhere "$arg" "" "${options[@]}"
          else
            # It's a session ID: cld fork <session-id> [options...]
            cmd_fork "$arg" "${options[@]}"
          fi
        else
          # cld fork <location> <session-id> [options...]
          local location="${non_option_args[0]}"
          local session_id="${non_option_args[1]}"
          cmd_fork_elsewhere "$location" "$session_id" "${options[@]}"
        fi
        ;;
    esac
  else
    # Not a known subcommand - check for interactive resume with options
    # If first arg starts with -, it's an option, check for previous session
    if [[ "$first_arg" =~ ^- ]]; then
      # Has options but no subcommand - check for previous session
      if is_in_tmux; then
        local session_id
        # Prefer new @meta.claude.session_id, fall back to legacy @claude_session
        session_id=$(tmux show-options -pv @meta.claude.session_id 2>/dev/null || true)
        if [[ -z "$session_id" ]]; then
          session_id=$(tmux show-options -pv @claude_session 2>/dev/null || true)
        fi

        # Check if --resume or --continue is in the args
        local has_resume=false
        for arg in "$@"; do
          if [[ "$arg" == "--resume" || "$arg" == "--continue" ]]; then
            has_resume=true
            break
          fi
        done

        if [[ -n "$session_id" ]] && [[ "$has_resume" == "false" ]]; then
          # Previous session found and no --resume/--continue, prompt user
          if prompt_resume "$session_id"; then
            # User wants to resume with options
            cmd_resume "$session_id" "$@"
          else
            # User wants new session with options
            exec "$CLAUDE_BIN" "$@"
          fi
        else
          # Either no session or already has --resume/--continue, pass through
          exec "$CLAUDE_BIN" "$@"
        fi
      else
        # Not in tmux, pass through
        exec "$CLAUDE_BIN" "$@"
      fi
    else
      # Unknown subcommand or regular claude arguments - pass everything through
      exec "$CLAUDE_BIN" "$@"
    fi
  fi
}

# Run main function
main "$@"
